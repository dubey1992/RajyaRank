# ============================================================================
# What this file does: tells Git which files to NEVER track or upload.
# This must exist BEFORE the first commit — anything matching these patterns
# is either a secret, a huge generated folder, or a personal machine setting
# that has no business being shared with everyone who can see this repository.
# ============================================================================

# --- Secrets: never commit these, under any name ---
.env
.env.local
.env.*.local
.env.development
.env.staging
.env.production
.env.preproduction
!.env.example
!.env.*.example
*.pem
*.key
!packages/**/*.d.ts
id_rsa
id_ed25519
*.p12
*.pfx
.aws/
.aws-credentials

# --- Dependencies (reinstalled from lock files, never uploaded) ---
node_modules/
.pnpm-store/

# --- Build output (regenerated by `pnpm build`, never uploaded) ---
dist/
build/
.next/
out/
.turbo/
*.tsbuildinfo

# --- Test / coverage output ---
coverage/
.nyc_output/
e2e/test-results/
e2e/playwright-report/
.playwright-mcp/

# --- Logs ---
*.log
npm-debug.log*
pnpm-debug.log*
logs/

# --- IDE / editor files ---
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Terraform (only ignore state — code itself should be tracked) ---
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# --- Prisma (generated client, not source) ---
apps/api/generated/

# --- Local scratch / screenshots taken during manual testing ---
*.png
!docs/**/*.png
!apps/*/public/**/*.png
