{
  "name": "@rajyarank/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "TS_NODE_PROJECT=tsconfig.dev.json node --watch -r ts-node/register -r tsconfig-paths/register src/main.ts",
    "build": "nest build --webpack",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "jest --passWithNoTests",
    "test:integration": "jest --config jest.integration.config.cjs --runInBand",
    "prisma": "prisma"
  },
  "prisma": {
    "seed": "TS_NODE_PROJECT=tsconfig.dev.json ts-node -r tsconfig-paths/register prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.658.1",
    "@aws-sdk/s3-request-presigner": "^3.658.1",
    "@nestjs/common": "^10.4.4",
    "@nestjs/core": "^10.4.4",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/throttler": "^6.2.1",
    "@prisma/client": "^5.20.0",
    "@rajyarank/auth": "workspace:*",
    "@rajyarank/config": "workspace:*",
    "@rajyarank/contracts": "workspace:*",
    "argon2": "^0.41.1",
    "cookie-parser": "^1.4.6",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "nestjs-pino": "^4.1.0",
    "nodemailer": "^6.9.15",
    "otplib": "^12.0.1",
    "pdfkit": "^0.19.1",
    "pino-http": "^10.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/testing": "^10.4.4",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.13",
    "@types/node": "^22.7.4",
    "@types/nodemailer": "^6.4.16",
    "@types/pdfkit": "^0.17.6",
    "@types/supertest": "^6.0.2",
    "@types/web-push": "^3.6.3",
    "ioredis-mock": "^8.13.1",
    "jest": "^29.7.0",
    "prisma": "^5.20.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.2"
  }
}
