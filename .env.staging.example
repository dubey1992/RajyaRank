# ============================================================================
# RajyaRank — STAGING environment. Copy to .env on the staging host / CI secret.
# NODE_ENV=production for real optimisations; APP_ENV distinguishes the tier.
# ============================================================================
NODE_ENV=production
APP_ENV=staging

# --- Public URLs (staging subdomains) ---
API_PUBLIC_URL=https://api.staging.rajyarank.in
WEB_PUBLIC_URL=https://staging.rajyarank.in
ADMIN_PUBLIC_URL=https://admin.staging.rajyarank.in
NEXT_PUBLIC_API_URL=https://api.staging.rajyarank.in

# --- Data (managed staging instances) ---
DATABASE_URL=postgresql://USER:PASS@db.staging.internal:5432/rajyarank?schema=public&sslmode=require
REDIS_URL=rediss://db.staging.internal:6379

# --- Auth / cookies (HTTPS only, shared parent domain for subdomain cookies) ---
JWT_ACCESS_SECRET=__set_in_secret_manager__
JWT_REFRESH_SECRET=__set_in_secret_manager__
FIELD_ENCRYPTION_KEY=__set_in_secret_manager__
COOKIE_DOMAIN=.staging.rajyarank.in
COOKIE_SECURE=true

# --- Providers (staging/test keys) ---
SMS_PROVIDER=msg91
SMS_API_KEY=__staging__
SMTP_HOST=smtp.staging-provider.com
SMTP_PORT=587
EMAIL_FROM="RajyaRank Staging <no-reply@staging.rajyarank.in>"
GOOGLE_CLIENT_ID=__staging__
GOOGLE_CLIENT_SECRET=__staging__
GOOGLE_CALLBACK_URL=https://api.staging.rajyarank.in/api/v1/auth/student/google/callback
S3_ENDPOINT=https://s3.ap-south-1.amazonaws.com
S3_REGION=ap-south-1
S3_ACCESS_KEY=__staging__
S3_SECRET_KEY=__staging__
S3_BUCKET_PRIVATE=rajyarank-staging-private
RAZORPAY_KEY_ID=rzp_test___staging__
RAZORPAY_KEY_SECRET=__staging__
RAZORPAY_WEBHOOK_SECRET=__staging__

LOG_LEVEL=info
DEFAULT_LOCALE=hi
