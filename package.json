{
  "name": "rajyarank",
  "version": "0.1.0",
  "private": true,
  "description": "RajyaRank — bilingual government-exam preparation platform for Bihar & Jharkhand",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "e2e": "turbo run e2e",
    "db:migrate": "pnpm --filter @rajyarank/api prisma migrate dev",
    "db:seed": "pnpm --filter @rajyarank/api prisma db seed",
    "db:generate": "pnpm --filter @rajyarank/api prisma generate",
    "docker:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f infra/docker/docker-compose.yml down",
    "i18n:check": "node scripts/i18n-check.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "eslint": "^9",
    "globals": "^17.7.0",
    "prettier": "^3.3.3",
    "tsx": "^4",
    "turbo": "^2.1.3",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.65.0"
  },
  "pnpm": {
    "overrides": {
      "typescript": "6.0.3"
    }
  }
}
