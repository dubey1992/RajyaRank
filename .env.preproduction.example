# ============================================================================
# RajyaRank — PRE-PRODUCTION (UAT) environment. Production-like, isolated data.
# Used for final acceptance + load/security testing before prod promotion.
# ============================================================================
NODE_ENV=production
APP_ENV=preproduction

# --- Public URLs (preprod subdomains) ---
API_PUBLIC_URL=https://api.preprod.rajyarank.in
WEB_PUBLIC_URL=https://preprod.rajyarank.in
ADMIN_PUBLIC_URL=https://admin.preprod.rajyarank.in
NEXT_PUBLIC_API_URL=https://api.preprod.rajyarank.in

# --- Data (isolated preprod instances; NEVER share prod credentials/data) ---
DATABASE_URL=postgresql://USER:PASS@db.preprod.internal:5432/rajyarank?schema=public&sslmode=require
REDIS_URL=rediss://db.preprod.internal:6379

# --- Auth / cookies ---
JWT_ACCESS_SECRET=__set_in_secret_manager__
JWT_REFRESH_SECRET=__set_in_secret_manager__
FIELD_ENCRYPTION_KEY=__set_in_secret_manager__
COOKIE_DOMAIN=.preprod.rajyarank.in
COOKIE_SECURE=true

# --- Providers (prod-like; Razorpay may still be test-mode for UAT) ---
SMS_PROVIDER=msg91
SMS_API_KEY=__preprod__
SMTP_HOST=smtp.provider.com
SMTP_PORT=587
EMAIL_FROM="RajyaRank UAT <no-reply@preprod.rajyarank.in>"
GOOGLE_CLIENT_ID=__preprod__
GOOGLE_CLIENT_SECRET=__preprod__
GOOGLE_CALLBACK_URL=https://api.preprod.rajyarank.in/api/v1/auth/student/google/callback
S3_ENDPOINT=https://s3.ap-south-1.amazonaws.com
S3_REGION=ap-south-1
S3_ACCESS_KEY=__preprod__
S3_SECRET_KEY=__preprod__
S3_BUCKET_PRIVATE=rajyarank-preprod-private
RAZORPAY_KEY_ID=rzp_test___preprod__
RAZORPAY_KEY_SECRET=__preprod__
RAZORPAY_WEBHOOK_SECRET=__preprod__

LOG_LEVEL=info
DEFAULT_LOCALE=hi
