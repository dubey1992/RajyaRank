# ============================================================================
# RajyaRank — PRODUCTION environment. All secrets come from the secret manager;
# never commit real values. Razorpay LIVE keys only here.
# ============================================================================
NODE_ENV=production
APP_ENV=production

# --- Public URLs (apex + subdomains) ---
API_PUBLIC_URL=https://api.rajyarank.in
WEB_PUBLIC_URL=https://rajyarank.in
ADMIN_PUBLIC_URL=https://admin.rajyarank.in
NEXT_PUBLIC_API_URL=https://api.rajyarank.in

# --- Data (managed HA Postgres + Redis; TLS enforced; automated backups) ---
DATABASE_URL=postgresql://USER:PASS@db.prod.internal:5432/rajyarank?schema=public&sslmode=require
REDIS_URL=rediss://db.prod.internal:6379

# --- Auth / cookies ---
JWT_ACCESS_SECRET=__secret_manager__
JWT_REFRESH_SECRET=__secret_manager__
FIELD_ENCRYPTION_KEY=__kms_managed__
COOKIE_DOMAIN=.rajyarank.in
COOKIE_SECURE=true

# --- Providers (LIVE) ---
SMS_PROVIDER=msg91
SMS_API_KEY=__secret_manager__
SMTP_HOST=smtp.provider.com
SMTP_PORT=587
EMAIL_FROM="RajyaRank <no-reply@rajyarank.in>"
GOOGLE_CLIENT_ID=__secret_manager__
GOOGLE_CLIENT_SECRET=__secret_manager__
GOOGLE_CALLBACK_URL=https://api.rajyarank.in/api/v1/auth/student/google/callback
S3_ENDPOINT=https://s3.ap-south-1.amazonaws.com
S3_REGION=ap-south-1
S3_ACCESS_KEY=__secret_manager__
S3_SECRET_KEY=__secret_manager__
S3_BUCKET_PRIVATE=rajyarank-prod-private
RAZORPAY_KEY_ID=rzp_live___secret_manager__
RAZORPAY_KEY_SECRET=__secret_manager__
RAZORPAY_WEBHOOK_SECRET=__secret_manager__

LOG_LEVEL=info
DEFAULT_LOCALE=hi
