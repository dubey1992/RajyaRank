# ============================================================================
# RajyaRank environment template. Copy to .env and fill in.
# NEVER commit a real .env. Each app reads only the vars it needs.
# ============================================================================

# --- Core ---
NODE_ENV=development
# Deployment tier: local | staging | preproduction | production
APP_ENV=local

# --- API (apps/api) ---
API_PORT=4000
# Public base URLs (drive CORS + links). See .env.{staging,preproduction,production}.example.
API_PUBLIC_URL=http://localhost:4000
WEB_PUBLIC_URL=http://localhost:3000

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://rajyarank:rajyarank@localhost:5432/rajyarank?schema=public

# --- Redis (cache, sessions, queues, rate-limit) ---
REDIS_URL=redis://localhost:6379

# --- Auth / sessions ---
# 32+ byte secrets. Generate: `openssl rand -base64 48`
JWT_ACCESS_SECRET=change-me-access-secret-min-32-bytes-long-please
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-bytes-long-please
ACCESS_TOKEN_TTL=600            # seconds (10 min)
REFRESH_TOKEN_TTL=2592000       # seconds (30 days)
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false             # true in staging/prod (HTTPS only)

# Encryption key for TOTP secrets & recovery codes (32 bytes, base64).
# In prod use a KMS-managed key; do NOT reuse the JWT secrets.
FIELD_ENCRYPTION_KEY=change-me-32-byte-base64-key================

# --- OTP / SMS provider (abstracted; dev uses log sink) ---
SMS_PROVIDER=log                # log | msg91 | twilio
SMS_API_KEY=
OTP_TTL=300                     # seconds (5 min)
OTP_MAX_ATTEMPTS=5

# --- Email (dev = mailhog) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="RajyaRank <no-reply@rajyarank.dev>"

# --- Google OAuth (student sign-in) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/student/google/callback

# --- Object storage (S3-compatible; dev = MinIO) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_PRIVATE=rajyarank-private

# --- Staff invitations ---
INVITATION_TTL_HOURS=48
ADMIN_PUBLIC_URL=http://localhost:3001   # used to build invite accept links

# --- Outbound notification email addresses ---
# Internal inbox the public "Contact Us" form emails to. Optional — if blank,
# submissions are still saved and visible to staff, just not emailed out.
CONTACT_NOTIFY_EMAIL=

# --- Payments (Razorpay) ---
# Leave blank in dev to disable live checkout; entitlements can be admin-granted for testing.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Rate limiting / lockout ---
LOGIN_MAX_FAILURES=5
LOGIN_LOCKOUT_MINUTES=15

# --- Frontend (apps/web, apps/admin) ---
# Read at BUILD time (Next.js "bakes in" NEXT_PUBLIC_* values when you run
# `next build` — changing this after building does nothing). This means
# staging and production need to be built as two separate images/builds,
# each with its own correct API URL. See DEPLOYMENT.md.
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Observability ---
LOG_LEVEL=info
# Error-tracking service (e.g. Sentry) project URL. Optional — leave blank to disable.
SENTRY_DSN=

# --- Web Push (VAPID) — empty disables push notifications. Generate with: npx web-push generate-vapid-keys ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:no-reply@rajyarank.in

# --- Upload malware scan provider: basic | clamav | external ---
# NOTE: only "basic" is currently implemented. clamav/external are accepted
# but not yet wired to a real scanner — see SECURITY_CHECKLIST.md.
ASSET_SCAN_PROVIDER=basic

# --- TESTING ONLY: skip staff MFA and issue AAL2 directly (non-prod; ignored when APP_ENV=production) ---
AUTH_DEV_SKIP_MFA=false
